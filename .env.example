# Why this exists: centralized runtime settings keep environments predictable
# and let you tune limits without changing code.
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGIN=*
TRUSTED_CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_FILES=20
MAX_FILE_SIZE_MB=25
MAX_TOTAL_UPLOAD_MB=120
PDF_EXTRACT_TO_DOCX_ENABLED=true
BOOKS_GREEK_EDITOR_ENABLED=true
BOOKS_EDITOR_TOKEN_AUTH_ENABLED=true
MUTATING_RATE_LIMIT_ENABLED=true
MUTATING_RATE_LIMIT_PER_MINUTE=5
ADMIN_TOKEN_STORE_FILE=data/admin-tokens.json
ADMIN_TOKEN_PEPPER=replace-this-in-production
ACCESS_USAGE_STORE_FILE=data/access-usage.sqlite
ACCESS_USAGE_HASH_SALT=replace-this-in-production
FAILURE_REPORT_HASH_SALT=replace-this-in-production
WEBHOOK_BIN_TTL_SECONDS=86400
WEBHOOK_BIN_MAX_BINS=300
WEBHOOK_BIN_MAX_ENTRIES_PER_BIN=120
WEBHOOK_BIN_MAX_PAYLOAD_BYTES=262144
