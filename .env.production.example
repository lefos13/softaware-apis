# Why this exists: this is the production runtime template for PM2-hosted API
# deploys, including the process metadata the deploy script reads.
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=https://api.example.com
CORS_ORIGIN=https://app.example.com,https://www.example.com
TRUSTED_CLIENT_ORIGINS=https://app.example.com,https://www.example.com
MAX_UPLOAD_FILES=20
MAX_FILE_SIZE_MB=25
MAX_TOTAL_UPLOAD_MB=120
PDF_EXTRACT_TO_DOCX_ENABLED=true
BOOKS_GREEK_EDITOR_ENABLED=true
BOOKS_EDITOR_TOKEN_AUTH_ENABLED=true
MUTATING_RATE_LIMIT_ENABLED=true
MUTATING_RATE_LIMIT_PER_MINUTE=5
ADMIN_TOKEN_STORE_FILE=data/admin-tokens.json
ADMIN_TOKEN_PEPPER=replace-with-a-long-random-secret
TOKEN_REQUEST_STORE_FILE=data/token-requests.json
TOKEN_REQUEST_DEFAULT_TTL=30d
ACCESS_USAGE_STORE_FILE=data/access-usage.sqlite
ACCESS_USAGE_HASH_SALT=replace-with-a-long-random-secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer-user
SMTP_PASS=replace-with-a-secret
EMAIL_PROVIDER=smtp
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_ACCESS_TOKEN=
EMAIL_FROM=Softaware Tools <noreply@example.com>
EMAIL_REPLY_TO=support@example.com
FAILURE_REPORT_HASH_SALT=replace-with-a-long-random-secret
WEBHOOK_BIN_TTL_SECONDS=86400
WEBHOOK_BIN_MAX_BINS=300
WEBHOOK_BIN_MAX_ENTRIES_PER_BIN=120
WEBHOOK_BIN_MAX_PAYLOAD_BYTES=262144
PM2_APP_NAME=softaware-apis
PM2_INSTANCES=1
PM2_MAX_MEMORY_RESTART=500M
PM2_LOG_DATE_FORMAT="YYYY-MM-DD HH:mm:ss Z"
# Optional: pin PM2 to a specific node binary if your host has multiple Node versions.
# PM2_NODE_INTERPRETER=/absolute/path/to/node
